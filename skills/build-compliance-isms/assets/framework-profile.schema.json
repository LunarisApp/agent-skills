{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Authorized ISMS Framework Identifier Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "frameworks",
    "requirement_ids",
    "control_ids",
    "soc2_criterion_ids"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "profile_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,63}$"
    },
    "frameworks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "edition", "source_reference"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 128 },
          "edition": { "type": "string", "minLength": 1, "maxLength": 64 },
          "source_reference": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "description": "Portable licence or publisher reference; never a machine-specific path or normative text."
          }
        }
      }
    },
    "requirement_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,63}$"
      }
    },
    "control_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,63}$"
      }
    },
    "soc2_criterion_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,63}$"
      }
    }
  }
}
